{
  "threshold": 3,
  "reporters": ["console"],
  "minLines": 7,
  "minTokens": 80,
  "ignore": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**"
  ],
  "format": ["typescript", "tsx"],
  "absolute": true,
  "gitignore": true
}
